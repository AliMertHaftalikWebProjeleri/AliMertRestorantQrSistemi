@model IEnumerable<AliMertRestoran.Models.Product>

@{
    ViewData["Title"] = "Menü";
    var groupedProducts = Model.GroupBy(p => p.Category?.Name).ToList();
    var allCategories = groupedProducts.Select(g => g.Key).ToList();
}

<!-- Hero Section -->
<div class="hero-section text-center text-white rounded-3 shadow-lg mb-5 overflow-hidden position-relative" style="background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?w=1200&q=80') center/cover no-repeat; min-height: 350px; display: flex; align-items: center; justify-content: center;">
    <div class="container px-4">
        <h1 class="display-3 fw-bold mb-3 text-shadow">Masa @ViewBag.CurrentTable - Menü</h1>
        <p class="lead fs-4 fw-light text-shadow">Dilediğiniz lezzeti sepetinize ekleyip anında sipariş verebilirsiniz.</p>
    </div>
</div>

<div class="container">
    
    <!-- Kategori Filtreleme Butonları -->
    <div class="d-flex flex-wrap justify-content-center gap-2 mb-5 sticky-top bg-white p-3 shadow-sm rounded-pill" style="top: 10px; z-index: 1000;" id="categoryFilters">
        <button class="btn btn-primary rounded-pill px-4 filter-btn" data-filter="all">Tümü</button>
        @foreach (var category in allCategories)
        {
            <button class="btn btn-outline-primary rounded-pill px-4 filter-btn" data-filter="@category.Replace(" ", "-").Replace("&", "and")">@category</button>
        }
    </div>

    <!-- Ürünler Listesi -->
    <div id="menu-start">
        @foreach (var group in groupedProducts)
        {
            var categoryIcon = group.Key switch
            {
                "Geleneksel Kebaplar" => "🍢",
                "Burger & Pizza" => "🍔",
                "Tatlılar" => "🍰",
                "Serinletici İçecekler" => "🍹",
                _ => "🍽️"
            };

            var filterClass = group.Key?.Replace(" ", "-").Replace("&", "and");

            <div class="category-section mb-5 category-group" data-category="@filterClass">
                <div class="d-flex align-items-center mb-4 mt-2">
                    <h2 class="fw-bold text-primary mb-0 me-3">@categoryIcon @group.Key</h2>
                    <hr class="flex-grow-1 border-primary opacity-25">
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var item in group)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 product-card overflow-hidden transition-all">
                                <div class="position-relative">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" class="card-img-top product-img" alt="@item.Name" style="height: 220px; object-fit: cover; transition: transform 0.5s;">
                                    }
                                    else
                                    {
                                        <div class="card-img-top bg-light d-flex align-items-center justify-content-center" style="height: 220px;">
                                            <i class="fs-1 text-muted">🍽️</i>
                                        </div>
                                    }
                                    <div class="position-absolute top-0 end-0 p-3">
                                        <span class="badge bg-warning text-dark fs-6 rounded-pill shadow">@item.Price.ToString("C")</span>
                                    </div>
                                </div>

                                <div class="card-body d-flex flex-column p-4">
                                    <h4 class="card-title fw-bold mb-2">@item.Name</h4>
                                    <p class="card-text text-muted small mb-4">
                                        @(item.Description ?? "Bu ürün için henüz açıklama girilmemiş.")
                                    </p>
                                    
                                    <div class="mt-auto">
                                        <form asp-controller="Cart" asp-action="AddToCart" method="post" class="d-grid gap-2">
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <button type="submit" class="btn btn-outline-primary btn-lg rounded-pill fw-bold hover-lift">
                                                <i class="me-2">🛒</i> Sepete Ekle
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</div>

<style>
    .product-card:hover { transform: translateY(-5px); box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important; }
    .product-card:hover .product-img { transform: scale(1.05); }
    .text-shadow { text-shadow: 2px 2px 4px rgba(0,0,0,0.5); }
    .transition-all { transition: all 0.3s ease; }
    .hover-lift:hover { transform: translateY(-2px); }
    [data-theme="dark"] .product-card { background-color: #1e1e1e; border: 1px solid #333; }
    [data-theme="dark"] .category-section h2 { color: #fff !important; }
    [data-theme="dark"] #categoryFilters { background-color: #1e1e1e !important; border: 1px solid #333; }
</style>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
            // 1. KATEGORİ FİLTRELEME MANTIĞI
            const filterBtns = document.querySelectorAll('.filter-btn');
            const categoryGroups = document.querySelectorAll('.category-group');

            filterBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Aktif buton stilini değiştir
                    filterBtns.forEach(b => {
                        b.classList.remove('btn-primary');
                        b.classList.add('btn-outline-primary');
                    });
                    this.classList.remove('btn-outline-primary');
                    this.classList.add('btn-primary');

                    const filterValue = this.getAttribute('data-filter');

                    categoryGroups.forEach(group => {
                        if (filterValue === 'all' || group.getAttribute('data-category') === filterValue) {
                            group.style.display = 'block';
                        } else {
                            group.style.display = 'none';
                        }
                    });
                });
            });

            // 2. GERİ TUŞU YAKALAMA VE MASADAN ÇIKIŞ MANTIĞI
            // Push a dummy state to history so back button can be intercepted
            history.pushState(null, null, location.href);
            
            window.addEventListener('popstate', function(event) {
                // Kullanıcı tarayıcının geri tuşuna bastığında tetiklenir
                // Ajax ile oturumu sonlandırıp ScanQR sayfasına atalım
                fetch('/Home/LeaveTable', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                }).then(() => {
                    // Oturum silindikten sonra ana sayfaya (ScanQR) git
                    window.location.href = '/';
                });
            });
        });
    </script>
}
