@{
    ViewData["Title"] = "QR Kod Okutun";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 text-center">
            <h2 class="fw-bold mb-3">Masadaki QR Kodu Okutun</h2>
            <p class="text-muted fs-5 mb-4">
                Sipariş verebilmek için masanızdaki QR kodu aşağıdaki kameraya gösterin, QR kod resmini yükleyin veya doğrudan masa linkini/numarasını girin.
            </p>

            <!-- Sekmeler -->
            <ul class="nav nav-tabs justify-content-center mb-4" id="qrTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold px-3" id="camera-tab" data-bs-toggle="tab" data-bs-target="#camera-pane" type="button" role="tab" aria-controls="camera-pane" aria-selected="true">
                        📷 Kameradan Okut
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-3" id="file-tab" data-bs-toggle="tab" data-bs-target="#file-pane" type="button" role="tab" aria-controls="file-pane" aria-selected="false">
                        📁 Resim Yükle
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-3" id="manual-tab" data-bs-toggle="tab" data-bs-target="#manual-pane" type="button" role="tab" aria-controls="manual-pane" aria-selected="false">
                        ⌨️ Manuel Giriş
                    </button>
                </li>
            </ul>

            <div class="tab-content" id="qrTabContent">
                <!-- Kamera Paneli -->
                <div class="tab-pane fade show active" id="camera-pane" role="tabpanel" aria-labelledby="camera-tab" tabindex="0">
                    <div class="card shadow-sm border-0 rounded-4 overflow-hidden">
                        <div class="card-body p-0 bg-dark position-relative" style="min-height: 400px; display: flex; justify-content: center; align-items: center;">
                            <div id="qr-reader" style="width: 100%; border: none;"></div>
                        </div>
                        <div class="card-footer bg-light p-3">
                            <button id="start-camera-btn" class="btn btn-primary btn-lg rounded-pill px-4">Kamerayı Başlat</button>
                            <button id="stop-camera-btn" class="btn btn-danger btn-lg rounded-pill px-4 d-none">Kamerayı Durdur</button>
                        </div>
                    </div>
                </div>

                <!-- Dosya Yükleme Paneli -->
                <div class="tab-pane fade" id="file-pane" role="tabpanel" aria-labelledby="file-tab" tabindex="0">
                    <div class="card shadow-sm border-0 rounded-4 p-5" style="border: 2px dashed #0d6efd !important;">
                        <div class="mb-4">
                            <span style="font-size: 60px;">📸</span>
                        </div>
                        <h4 class="mb-3">QR Kod Görselini Buraya Sürükleyin veya Seçin</h4>
                        <input type="file" id="qr-file-input" class="form-control form-control-lg mt-3" accept="image/*">
                        <div id="file-scan-result" class="mt-3 text-success fw-bold fs-5"></div>
                        <div id="file-scan-error" class="mt-3 text-danger fw-bold"></div>
                    </div>
                </div>

                <!-- Manuel Link/Numara Giriş Paneli -->
                <div class="tab-pane fade" id="manual-pane" role="tabpanel" aria-labelledby="manual-tab" tabindex="0">
                    <div class="card shadow-sm border-0 rounded-4 p-5">
                        <div class="mb-4">
                            <span style="font-size: 60px;">🔗</span>
                        </div>
                        <h4 class="mb-3">Link veya Masa Numarası Girin</h4>
                        <p class="text-muted mb-4">Kameranızı kullanamıyorsanız QR kodun linkini yapıştırabilir veya direkt masa numaranızı girebilirsiniz.</p>
                        
                        <div class="input-group input-group-lg mb-3">
                            <input type="text" id="manual-input" class="form-control" placeholder="Örn: 3 veya siteniz.com/?tableNumber=3" aria-label="Masa Numarası veya Link">
                            <button class="btn btn-primary px-4" type="button" id="manual-submit-btn">Git</button>
                        </div>
                        <div id="manual-error" class="text-danger fw-bold mt-2" style="display: none;">Geçerli bir değer girmediniz.</div>
                    </div>
                </div>
            </div>

            <div class="alert alert-info mt-4" role="alert">
                <i class="me-2">ℹ️</i> İşlem başarılı olduğunda otomatik olarak menüye yönlendirileceksiniz.
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://unpkg.com/html5-qrcode" type="text/javascript"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            
            let html5QrcodeScanner = null;
            const startBtn = document.getElementById('start-camera-btn');
            const stopBtn = document.getElementById('stop-camera-btn');
            const fileInput = document.getElementById('qr-file-input');
            const fileResult = document.getElementById('file-scan-result');
            const fileError = document.getElementById('file-scan-error');
            const manualSubmitBtn = document.getElementById('manual-submit-btn');
            const manualInput = document.getElementById('manual-input');
            const manualError = document.getElementById('manual-error');

            function onScanSuccess(decodedText, decodedResult) {
                if(decodedText.includes('tableNumber=')) {
                    if (html5QrcodeScanner) {
                        html5QrcodeScanner.clear();
                    }
                    window.location.href = decodedText;
                } else {
                    alert("Okutulan kod geçerli bir masa QR kodu değil: " + decodedText);
                }
            }

            // Kamera Başlatma
            startBtn.addEventListener('click', function() {
                startBtn.classList.add('d-none');
                stopBtn.classList.remove('d-none');
                
                html5QrcodeScanner = new Html5QrcodeScanner(
                    "qr-reader", { fps: 10, qrbox: { width: 250, height: 250 } }, false);
                html5QrcodeScanner.render(onScanSuccess);
            });

            // Kamera Durdurma
            stopBtn.addEventListener('click', function() {
                if (html5QrcodeScanner) {
                    html5QrcodeScanner.clear().then(() => {
                        stopBtn.classList.add('d-none');
                        startBtn.classList.remove('d-none');
                        document.getElementById('qr-reader').innerHTML = ''; 
                    });
                }
            });

            // Dosya Okutma İşlemi
            const html5QrCodeFile = new Html5Qrcode("qr-reader"); 
            fileInput.addEventListener('change', e => {
                if (e.target.files.length == 0) {
                    return;
                }
                const imageFile = e.target.files[0];
                fileResult.innerText = "Taranıyor...";
                fileError.innerText = "";

                html5QrCodeFile.scanFile(imageFile, true)
                .then(decodedText => {
                    fileResult.innerText = "Başarılı! Yönlendiriliyorsunuz...";
                    onScanSuccess(decodedText, null);
                })
                .catch(err => {
                    fileResult.innerText = "";
                    fileError.innerText = "QR kod bulunamadı. Lütfen net bir fotoğraf seçin.";
                });
            });

            // Manuel Giriş İşlemi
            manualSubmitBtn.addEventListener('click', function() {
                manualError.style.display = 'none';
                let val = manualInput.value.trim();
                
                if(!val) {
                    manualError.style.display = 'block';
                    return;
                }

                // Eğer direkt sayı girildiyse (Örn: 3) linke dönüştür
                if (!isNaN(val) && val > 0) {
                    window.location.href = "/?tableNumber=" + val;
                } 
                // Eğer link yapıştırıldıysa ve içinde tableNumber varsa
                else if (val.includes('tableNumber=')) {
                    window.location.href = val;
                } 
                else {
                    manualError.innerText = "Lütfen sadece masa numarası (Örn: 3) veya geçerli bir link girin.";
                    manualError.style.display = 'block';
                }
            });

            // Enter tuşu ile manuel giriş
            manualInput.addEventListener('keypress', function(e) {
                if(e.key === 'Enter') {
                    manualSubmitBtn.click();
                }
            });

            // Sekme değiştirirken kamerayı durdur
            const stopCameraIfRunning = function() {
                if (html5QrcodeScanner) {
                    html5QrcodeScanner.clear();
                    stopBtn.classList.add('d-none');
                    startBtn.classList.remove('d-none');
                }
            };

            document.getElementById('file-tab').addEventListener('click', stopCameraIfRunning);
            document.getElementById('manual-tab').addEventListener('click', stopCameraIfRunning);
        });
    </script>
}
