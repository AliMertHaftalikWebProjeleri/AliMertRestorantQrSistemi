@{
    ViewData["Title"] = "Dashboard";
    Layout = "_AdminLayout";
}

<div class="row mt-4 mb-4">
    <!-- Günlük İstatistikler -->
    <div class="col-md-4">
        <div class="card text-white bg-success shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Bugün Gelen Sipariş</h5>
                <h2 class="display-5 fw-bold">@ViewBag.TotalOrdersToday</h2>
                <p class="card-text">Adet yeni sipariş alındı.</p>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card text-white bg-info shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Bugünkü Hasılat</h5>
                <h2 class="display-5 fw-bold">@(((decimal)ViewBag.TotalRevenueToday).ToString("C"))</h2>
                <p class="card-text">Bugün elde edilen toplam gelir.</p>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card text-white bg-primary shadow-sm mb-3">
            <div class="card-body">
                <h5 class="card-title">Toplam Hasılat (Tüm Zamanlar)</h5>
                <h2 class="display-5 fw-bold">@(((decimal)ViewBag.TotalRevenueAllTime).ToString("C"))</h2>
                <p class="card-text">Sistemin kurulduğundan beri geliri.</p>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Grafik Alanı -->
    <div class="col-md-10 offset-md-1">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
                <h5 class="mb-0">En Çok Tercih Edilen Menüler (Tüm Zamanlar)</h5>
                <i class="fs-4">📊</i>
            </div>
            <div class="card-body">
                <canvas id="popularMenusChart" style="max-height: 400px;"></canvas>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var ctx = document.getElementById('popularMenusChart').getContext('2d');
        
        var labels = @Html.Raw(Json.Serialize(ViewBag.ChartLabels));
        var dataValues = @Html.Raw(Json.Serialize(ViewBag.ChartData));

        var chart = new Chart(ctx, {
            type: 'bar',
            data: {
                labels: labels,
                datasets: [{
                    label: 'Toplam Sipariş Adedi',
                    data: dataValues,
                    backgroundColor: [
                        'rgba(255, 99, 132, 0.6)',
                        'rgba(54, 162, 235, 0.6)',
                        'rgba(255, 206, 86, 0.6)',
                        'rgba(75, 192, 192, 0.6)',
                        'rgba(153, 102, 255, 0.6)'
                    ],
                    borderColor: [
                        'rgba(255, 99, 132, 1)',
                        'rgba(54, 162, 235, 1)',
                        'rgba(255, 206, 86, 1)',
                        'rgba(75, 192, 192, 1)',
                        'rgba(153, 102, 255, 1)'
                    ],
                    borderWidth: 2,
                    borderRadius: 5
                }]
            },
            options: {
                responsive: true,
                plugins: {
                    legend: {
                        position: 'top',
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1
                        }
                    }
                }
            }
        });
    </script>
}
